{
  "name": "fai-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.json --noEmit && vite build",
    "build:engine": "esbuild src/engine/index.ts --bundle --format=esm --platform=neutral --outfile=dist-engine/index.js",
    "test": "vitest run",
    "batch": "npm run build:engine && node scripts/batch.mjs",
    "build:flatten": "esbuild src/studio/flatten-core.ts --bundle --format=esm --platform=neutral --outfile=dist-flatten/flatten-core.js",
    "flatten:dir": "npm run build:flatten && node scripts/flatten-dir.mjs"
  },
  "devDependencies": {
    "canvas": "^3.2.3",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "paper": "^0.12.18"
  }
}